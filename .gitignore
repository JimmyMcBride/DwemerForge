# brain:begin gitignore-session
.brain/session.json
.brain/sessions/
.brain/policy.override.yaml
.brain/state/
# brain:end gitignore-session

# Brain generated proposal scratch files; durable conclusions should be promoted
# into .brain/context, docs, or .plan before commit.
.brain/resources/changes/*-distill-proposal.md

# Node / pnpm
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
out/
release/
.svelte-kit/
.vercel/
coverage/

# Environment files
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
*.tsbuildinfo
