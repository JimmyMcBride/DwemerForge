{
  "name": "@dwemerforge/desktop",
  "version": "0.0.0",
  "private": true,
  "author": "Jimmy McBride",
  "description": "Electron shell for the DwemerForge ESO addon manager.",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "build": "electron-vite build",
    "dev": "electron-vite dev",
    "dist": "pnpm build && electron-builder --publish never",
    "preview": "electron-vite preview",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && svelte-check --tsconfig ./tsconfig.web.json"
  },
  "dependencies": {
    "@dwemerforge/eso-core": "workspace:*",
    "@dwemerforge/providers": "workspace:*",
    "@dwemerforge/registry": "workspace:*",
    "@dwemerforge/ui": "workspace:*"
  },
  "build": {
    "appId": "app.dwemerforge.desktop",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**",
      "package.json"
    ],
    "linux": {
      "category": "Utility",
      "target": [
        "dir"
      ]
    },
    "mac": {
      "target": [
        "dir"
      ]
    },
    "productName": "DwemerForge",
    "publish": [
      {
        "provider": "github",
        "owner": "JimmyMcBride",
        "repo": "DwemerForge"
      }
    ],
    "win": {
      "target": [
        "dir"
      ]
    }
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "svelte": "^5.55.5",
    "vite": "^7.3.2"
  }
}
