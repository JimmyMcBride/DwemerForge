{
  "name": "dwemerforge",
  "version": "0.0.0",
  "private": true,
  "description": "Independent ESO addon manager and registry.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "build:desktop": "pnpm --filter @dwemerforge/desktop build",
    "build:web": "pnpm --filter @dwemerforge/web build",
    "ci": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "dev:desktop": "pnpm --filter @dwemerforge/desktop dev",
    "dev:web": "pnpm --filter @dwemerforge/web dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm -r --if-present typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.19.17",
    "eslint": "^10.2.1",
    "eslint-plugin-svelte": "^3.17.1",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte-check": "^4.4.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller",
      "esbuild"
    ]
  }
}
